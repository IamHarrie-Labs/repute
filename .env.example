# =============================================================
#  Repute · Environment Variables
#  Copy this file to .env and fill in your values.
#  Required fields are marked [REQUIRED].
#  Fields marked [DEMO] can be left blank in DEMO_MODE=true.
# =============================================================


# -------------------------------------------------------------
#  GENERAL
# -------------------------------------------------------------

# Set to true to run with simulated payments (no real USDC moves).
# The live feed, battle panel, and scoring all work normally.
# Set to false when Circle wallets are funded and you want real txs.
DEMO_MODE=true


# -------------------------------------------------------------
#  ARC TESTNET
# -------------------------------------------------------------

# "simulate" = local mock (no RPC needed, good for quick dev)
# "arc"      = live Arc testnet (requires ARC_RPC_URL below)
INDEXER_MODE=simulate

# [REQUIRED if INDEXER_MODE=arc]
# Get your RPC URL from the Arc Canteen dashboard.
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_KEY_HERE

# Arc testnet USDC contract address (do not change)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Repute's own wallet — collects x402 query fees when the score
# API gate is enabled. Can be any Arc address you control.
RECEIPT_LAYER_WALLET=0xYOUR_REPUTE_WALLET_ADDRESS


# -------------------------------------------------------------
#  CIRCLE DEVELOPER-CONTROLLED WALLETS
#  Sign up at: https://console.circle.com
#  Docs: https://developers.circle.com/w3s/developer-controlled-wallets
# -------------------------------------------------------------

# [REQUIRED for live payments]
CIRCLE_API_KEY=TEST_API_KEY:your_key_here

# Your entity secret (generated once, keep it safe — never commit the real one)
CIRCLE_ENTITY_SECRET=your_entity_secret_here

# Wallet set ID (created during pnpm provision)
# Leave blank — filled automatically by the provision script.
CIRCLE_WALLET_SET_ID=

# Circle wallet IDs for the buyer agents.
# Created by: pnpm provision
# Fund at: https://faucet.circle.com (select Arc Testnet, 20 USDC per address)
CIRCLE_BUYER_NAIVE_WALLET_ID=
CIRCLE_BUYER_REPUTE_WALLET_ID=


# -------------------------------------------------------------
#  API SERVER
# -------------------------------------------------------------

API_PORT=3001


# -------------------------------------------------------------
#  MERCHANT AGENTS (6 local HTTP servers, ports 4001-4006)
#  These are pre-generated test keys for Arc testnet only.
#  Each merchant has a private key (for signing) + its address.
#  You can regenerate with: pnpm provision
# -------------------------------------------------------------

MERCHANT_1_PK=0x_merchant_1_private_key
MERCHANT_1_ADDRESS=0x_merchant_1_address

MERCHANT_2_PK=0x_merchant_2_private_key
MERCHANT_2_ADDRESS=0x_merchant_2_address

MERCHANT_3_PK=0x_merchant_3_private_key
MERCHANT_3_ADDRESS=0x_merchant_3_address

MERCHANT_4_PK=0x_merchant_4_private_key
MERCHANT_4_ADDRESS=0x_merchant_4_address

MERCHANT_5_PK=0x_merchant_5_private_key
MERCHANT_5_ADDRESS=0x_merchant_5_address

MERCHANT_6_PK=0x_merchant_6_private_key
MERCHANT_6_ADDRESS=0x_merchant_6_address


# -------------------------------------------------------------
#  BUYER AGENTS
#  Two autonomous agents that run the live benchmark:
#  - NaiveAgent: picks merchants at random, no trust check
#  - ReputeAgent: queries Repute scores, routes to trusted nodes
#
#  In DEMO_MODE=true the private keys are not used for real txs.
#  In DEMO_MODE=false, Circle wallet IDs take priority;
#  private keys are the fallback if no wallet ID is set.
# -------------------------------------------------------------

BUYER_NAIVE_PK=0x_naive_agent_private_key
BUYER_NAIVE_ADDRESS=0x_naive_agent_address

BUYER_REPUTE_PK=0x_repute_agent_private_key
BUYER_REPUTE_ADDRESS=0x_repute_agent_address
